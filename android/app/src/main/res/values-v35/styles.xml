<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 15 enforces edge-to-edge for targetSdk 35+, but uCrop's
         activity doesn't apply window insets — its toolbar renders under
         the status bar. Opt this one activity out of the enforcement. -->
    <style name="UCropTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
